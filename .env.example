# Database
# Local dev: use SQLite (default)
# Production (Railway): PostgreSQL connection string (auto-set by addon)
DATABASE_URL="file:./dev.db"

# OpenAI (for AI briefings and chat)
# Get yours at: https://platform.openai.com/api-keys
# OPENAI_API_KEY="sk-..."

# ElevenLabs (for voice features)
# ELEVENLABS_API_KEY="..."

# Stripe (for billing)
# Get yours at: https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_PUBLISHABLE_KEY="pk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs (created in Stripe Dashboard)
# STRIPE_PRICE_STARTER_MONTHLY="price_..."
# STRIPE_PRICE_STARTER_ANNUAL="price_..."
# STRIPE_PRICE_PRO_MONTHLY="price_..."
# STRIPE_PRICE_PRO_ANNUAL="price_..."
# STRIPE_PRICE_ENTERPRISE_MONTHLY="price_..."
# STRIPE_PRICE_ENTERPRISE_ANNUAL="price_..."

# Server
PORT=3001
